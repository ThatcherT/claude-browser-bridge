{
  "manifest_version": 3,
  "name": "Browser Bridge",
  "version": "2.1.0",
  "description": "MCP bridge for Claude Code browser control",
  "permissions": ["activeTab", "tabs", "tabGroups", "scripting", "alarms", "debugger", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Browser Bridge"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
